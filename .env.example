# Supabase warehouse connection (browser-safe values).
# Copy to `.env` and fill in. `.env` is gitignored — never commit real values.

# Supabase project URL, e.g. https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (safe to expose in the browser).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site URL for link previews (Open Graph). Set to your production
# domain in Cloudflare Pages, e.g. https://castlingfinancial.com
NEXT_PUBLIC_SITE_URL=
